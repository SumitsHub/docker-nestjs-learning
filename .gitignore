# --- Node ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Build output ---
dist/
build/
*.tsbuildinfo

# --- Env & secrets — NEVER commit ---
.env
.env.*
!.env.example

# --- Yarn 4 (Berry) — commit the pinned yarn release, ignore the rest ---
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.yarn/cache
.yarn/install-state.gz
.pnp.*

# --- IDE / editor ---
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# --- OS ---
.DS_Store
Thumbs.db

# --- Coverage / test artifacts ---
coverage/
.nyc_output/

# --- Docker ---
# We DO commit Dockerfiles and compose files.
# Only ignore local overrides:
compose.override.yaml

# Yarn 4 (Berry) — we commit the pinned Yarn release itself
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.yarn/cache
.yarn/install-state.gz
.pnp.*