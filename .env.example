# Copy this to `.env` and adjust. `.env` is gitignored; `.env.example` is committed.
# Compose loads `.env` from the same directory as `compose.yaml` automatically,
# and every ${VAR:-default} in compose.yaml is filled from here.

# ---- Postgres ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=devpass
POSTGRES_DB=appdb
POSTGRES_PORT=5432

# ---- Redis ----
# Not used by the default `docker compose up` (redis is behind the `cache`
# profile in compose.yaml). Uncomment + set if you `--profile cache` AND
# want to publish the redis port to your host (pick 6380 or another free
# port if you already have a local redis on 6379).
# REDIS_PORT=6380

# ---- Application ----
API_PORT=3000
