# Copy this to `.env` and adjust. `.env` is gitignored; `.env.example` is committed.
#
# Two-layer model — same variable names work in both:
#   1. Compose CLI reads this file and fills every ${VAR:-default} in compose.yaml.
#   2. @nestjs/config reads this file when you run `yarn start:*` on the host.
# In production (K8s), each Deployment gets its own ConfigMap + Secret; there
# is NO shared .env file. This file is a local-dev convenience only.

# ---- Database ----
# Used by:
#   - postgres image env (POSTGRES_USER/PASSWORD/DB, translated in compose.yaml)
#   - users-service container env (DB_USER/PASSWORD/NAME — same names)
#   - `yarn start:users` on host (reads the same names via @nestjs/config)
DB_USER=postgres
DB_PASSWORD=devpass
DB_NAME=appdb

# Host-side port publish for postgres (for `psql` from your laptop).
# NOT the port the app uses — inside compose the app always talks to
# postgres:5432 on the compose network.
DB_HOST_PORT=5432

# ---- Redis ----
# On the compose network, api-gateway reaches redis at redis://redis:6379
# (that's already baked into compose.yaml). For LOCAL DEV outside compose
# (running yarn start:gateway on your host), REDIS_URL defaults to
# redis://127.0.0.1:6379 — no need to set it here unless you use a
# different host/port.
# REDIS_URL=redis://127.0.0.1:6379

# Host-side port publish for redis (so host-run apps can reach it).
# If you already run a local redis on 6379, bump this to 6380 AND set
# REDIS_URL=redis://127.0.0.1:6380 above so the app follows.
REDIS_HOST_PORT=6379

# ---- Application ----
API_PORT=3000
